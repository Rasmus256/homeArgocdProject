{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor"
  ],
  "packageRules": [
    {
      "automerge": true,
      "ignoreTests": true,
      "matchPackageNames": [
        "/.*/"
      ]
    },
    {
      "matchPackageNames": [
        "homeassistant/home-assistant"
      ],
      "matchUpdateTypes": [
        "major",
        "minor"
      ],
      "automerge": false,
      "ignoreTests": true
    }
  ]
}
